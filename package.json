{
    "name": "ask-transcript",
    "version": "3.5.0",
    "description": "Ask Transcript - Search, AI chat, and auto-generated topics",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && BUILD_TARGET=content vite build && vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/ tests/",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/node": "^25.2.0",
        "@vitest/coverage-v8": "^4.0.18",
        "chrome-types": "^0.1.327",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "jsdom": "^24.0.0",
        "prettier": "^3.8.1",
        "typescript": "^5.3.0",
        "typescript-eslint": "^8.55.0",
        "vite": "^5.4.0",
        "vitest": "^4.0.0"
    },
    "dependencies": {
        "marked": "^17.0.2"
    }
}
